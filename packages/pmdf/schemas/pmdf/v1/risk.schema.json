{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pmdf.dev/schemas/v1/risk.schema.json",
  "title": "PMDF Risk",
  "type": "object",
  "properties": {
    "pmdf_version": { "$ref": "common.schema.json#/$defs/pmdf_version" },
    "kind": { "const": "risk" },
    "id": { "$ref": "common.schema.json#/$defs/id" },
    "provenance": { "$ref": "common.schema.json#/$defs/provenance" },
    "attachments": { "$ref": "common.schema.json#/$defs/attachments" },
    "product": {
      "$ref": "common.schema.json#/$defs/id",
      "x_ref_kind": "product"
    },
    "event": {
      "type": "string",
      "description": "リスク事象の説明。"
    },
    "probability_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "PMBOKリスク領域準拠の確率スコア(1-5)。"
    },
    "impact_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "PMBOKリスク領域準拠の影響スコア(1-5)。"
    },
    "response_strategy": {
      "type": "string",
      "enum": ["avoid", "transfer", "mitigate", "accept"],
      "description": "対応戦略(回避/転嫁/軽減/受容)。"
    },
    "owner": {
      "$ref": "common.schema.json#/$defs/id",
      "x_ref_kind": "stakeholder"
    }
  },
  "patternProperties": {
    "^x_": {}
  },
  "required": [
    "pmdf_version",
    "kind",
    "id",
    "provenance",
    "event",
    "probability_score",
    "impact_score",
    "response_strategy",
    "owner"
  ],
  "additionalProperties": false
}
