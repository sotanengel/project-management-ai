# このファイルをコピーして .env を作成すること。値はすべてダミー。
# cp .env.example .env

# --- ポート(ホスト公開分。SEC-02: web-ui/api-serverのみ外部公開) -----------
WEB_UI_HOST_PORT=8080
API_SERVER_HOST_PORT=8000

# --- サービス間URL(内部ネットワーク名前解決) -------------------------------
API_BASE_URL=http://api-server:8000
MODEL_GATEWAY_URL=http://model-gateway:4000
MODEL_GATEWAY_PORT=4000
QDRANT_URL=http://qdrant:6333
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=sqlite:////data/mlflow.db
MLFLOW_ARTIFACT_ROOT=/data/artifacts

# --- PMDF(プロジェクト管理データ基盤)ストレージ ----------------------------
PMDF_STORE_PATH=/data/pmdf

# --- LLM APIキー(ダミー。実キーはSecrets Manager/Parameter Store等で管理) --
ANTHROPIC_API_KEY=dummy
OPENAI_API_KEY=dummy

# --- model-gateway: 論理名→実モデルの割当(E4-1) ----------------------------
# 論理名(pdm-main/pdm-teacher/pdm-judge/pdm-embed)はコードに一切ハードコード
# せず、ここでの割当のみで実モデルを決定する(AR-01)。
#
# E4-5: ACTIVE_BACKEND=api|ollama で pdm-main の実バックエンドを切替。
# model-gateway コンテナの entrypoint が PDM_MAIN_MODEL / PDM_MAIN_API_BASE を
# 設定する(YAML/compose は変更しない)。
ACTIVE_BACKEND=api
PDM_MAIN_MODEL=anthropic/claude-sonnet-4-5
PDM_TEACHER_MODEL=anthropic/claude-opus-4
PDM_JUDGE_MODEL=openai/gpt-4o
PDM_EMBED_MODEL=openai/text-embedding-3-large

# ローカルOllama切替例(pdm-main-local、.envの値変更のみでYAML無改修切替)。
# 実際にローカルバックエンドを使う場合、compose profile "local-gpu" で
# ollamaサービスを起動すること。
PDM_MAIN_LOCAL_MODEL=ollama/qwen2.5:7b-instruct-q4_K_M
PDM_MAIN_LOCAL_API_BASE=http://ollama:11434

# フォールバック例(pdm-main-fallback、E4-2: 主バックエンド障害時にBedrock経由へ)。
PDM_MAIN_FALLBACK_MODEL=bedrock/anthropic.claude-3-5-sonnet

# LiteLLMのspend tracking用DB接続文字列(E4-3、Tier-Lではファイルベース
# SQLiteでも可。未設定時はapi-server側の軽量コスト記録ストアで代替する)。
LITELLM_DATABASE_URL=sqlite:////data/litellm_spend.db

# --- MinIO(オブジェクトストレージ、MLflowアーティファクト用) ---------------
MINIO_ROOT_USER=dummy
MINIO_ROOT_PASSWORD=dummy_password_1234

# --- 認証(api-server) ------------------------------------------------------
JWT_SECRET=dummy_secret

# --- AWSデプロイ用(ダミー。ローカル開発では未使用) --------------------------
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy
AWS_REGION=ap-northeast-1

# --- コスト管理 -------------------------------------------------------------
BUDGET_MONTHLY_JPY=50000

# --- scheduler (E9-1) -------------------------------------------------------
SCHEDULER_KPI_CRON=0 * * * *
SCHEDULER_WEEKLY_REVIEW_CRON=0 9 * * 1
SCHEDULER_LEARNING_LOOP_CRON=0 2 * * 0
SCHEDULER_PRODUCT_ID=product-sample
SCHEDULER_METRIC_ID=metric-sample
SCHEDULER_PROPOSER=scheduler@system
SCHEDULER_AUTH_TOKEN=
